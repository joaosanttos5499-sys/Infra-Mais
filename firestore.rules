/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model for profile data,
 * but allows public read access to infrastructure reports so the community can
 * visualize and support urban maintenance issues.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    match /users/{userId} {
      // Perfil privado: apenas o dono lê e edita
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
      
      match /reports/{reportId} {
        // Relatos são públicos para leitura (Mapa e Dashboard)
        allow read: if true;
        // Criação e edição restrita ao dono ou lógica de servidor
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }
    }

    // Permite consultas de Collection Group para relatos (Mapa Global)
    match /{path=**}/reports/{reportId} {
      allow read: if true;
    }

    // Notificações e Denúncias (Uso interno/funcionário)
    match /notifications/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow write: if isSignedIn();
    }

    match /complaints/{id} {
      allow read, write: if isSignedIn();
    }
  }
}