/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model for profile data,
 * but allows public read access to infrastructure reports so the community can
 * visualize and support urban maintenance issues.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmployee() {
      // Lista de e-mails autorizados (deve bater com src/lib/config.ts)
      return isSignedIn() && request.auth.token.email.matches('.*@gmail.com') && (
        request.auth.token.email == 'joaosanttos528@gmail.com'
      );
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    match /users/{userId} {
      // Perfil: dono lê/edita, outros não vêem
      allow get: if isOwner(userId) || isEmployee();
      allow list: if isEmployee();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isEmployee();
      allow delete: if isOwner(userId);
      
      match /reports/{reportId} {
        // Relatos individuais são públicos para leitura (Mapa/Dashboard)
        allow read: if true;
        // Criação restrita ao dono
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        // Edição pelo dono ou funcionário
        allow update: if isOwner(userId) || isEmployee();
        allow delete: if isOwner(userId) || isEmployee();
      }
    }

    // Permite consultas de Collection Group para relatos (Mapa Global e Dashboard)
    match /{path=**}/reports/{reportId} {
      allow read: if true;
    }

    // Notificações: apenas o destinatário lê
    match /notifications/{id} {
      // Permite listagem se o filtro da query bater com o dono
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isEmployee());
      // Criação pelo sistema (qualquer logado pode disparar via trigger/action)
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isEmployee());
      allow delete: if isEmployee();
    }

    // Denúncias: apenas funcionários
    match /complaints/{id} {
      allow read, list: if isEmployee();
      allow create: if isSignedIn(); // Qualquer usuário pode denunciar
      allow update, delete: if isEmployee();
    }
  }
}