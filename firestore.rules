/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model for profile data,
 * but allows public read access to infrastructure reports so the community can
 * visualize and support urban maintenance issues.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    match /users/{userId} {
      // Perfil privado: apenas o dono lê e edita
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
      
      match /reports/{reportId} {
        // Relatos individuais são públicos para leitura
        allow read: if true;
        // Criação e edição restrita ao dono
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isOwner(userId);
      }
    }

    // Permite consultas de Collection Group para relatos (Mapa Global e Dashboard)
    // Essencial para o funcionamento do sistema de zeladoria urbana
    match /{path=**}/reports/{reportId} {
      allow read: if true;
    }

    // Notificações: apenas o destinatário lê
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isSignedIn();
    }

    // Denúncias: apenas usuários logados (em um cenário real, haveria check de funcionário)
    match /complaints/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}